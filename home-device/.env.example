# =============================================================================
# DarkPipe Home Device — Environment Variables
# =============================================================================
# Copy this file to .env and customize for your deployment.
# Source: home-device/docker-compose.yml
#
# Legend:
#   # Required   — must be set for the stack to function
#   # Optional   — has a sensible default; override as needed
#
# Mail server profiles (pick one):
#   --profile stalwart          Stalwart (modern, all-in-one)
#   --profile maddy             Maddy (minimal, Go-based)
#   --profile postfix-dovecot   Postfix+Dovecot (traditional)
#
# Webmail profiles (pick one):
#   --profile roundcube         Roundcube (feature-rich)
#   --profile snappymail        SnappyMail (lightweight)
#
# CalDAV/CardDAV profiles:
#   --profile radicale          Radicale (for Maddy or Postfix+Dovecot)
#   (Stalwart has built-in CalDAV/CardDAV — no extra profile needed)

# -----------------------------------------------------------------------------
# Domain & Identity
# Source: docker-compose.yml (shared across all mail server profiles)
# -----------------------------------------------------------------------------

# Required — primary mail domain
MAIL_DOMAIN=example.com

# Required — mail server hostname (must have DNS pointing to this device)
MAIL_HOSTNAME=mail.example.com

# -----------------------------------------------------------------------------
# User Configuration
# Source: docker-compose.yml (stalwart, postfix-dovecot, profile-server)
# -----------------------------------------------------------------------------

# Required — admin email address
ADMIN_EMAIL=admin@example.com

# Required — admin password (CHANGE THIS!)
ADMIN_PASSWORD=changeme

# Optional — additional virtual domains (postfix-dovecot only, comma-separated)
# VIRTUAL_DOMAINS=example.com, example.org

# -----------------------------------------------------------------------------
# Mail Server Selection
# Source: docker-compose.yml (profile-server)
# -----------------------------------------------------------------------------

# Required — which mail server profile is active: "stalwart", "maddy", or "postfix-dovecot"
MAIL_SERVER_TYPE=stalwart

# -----------------------------------------------------------------------------
# Profile Server (device onboarding & monitoring)
# Source: docker-compose.yml (profile-server service)
# -----------------------------------------------------------------------------

# Optional — port the profile server listens on
PROFILE_SERVER_PORT=8090

# Optional — CalDAV server URL (auto-detected for Stalwart; set for Radicale)
# CALDAV_URL=http://radicale:5232

# Optional — CardDAV server URL (auto-detected for Stalwart; set for Radicale)
# CARDDAV_URL=http://radicale:5232

# -----------------------------------------------------------------------------
# Monitoring & Alerting
# Source: docker-compose.yml (profile-server service)
# -----------------------------------------------------------------------------

# Optional — email address for monitoring alerts
# MONITOR_ALERT_EMAIL=admin@example.com

# Optional — webhook URL for monitoring alerts
# MONITOR_WEBHOOK_URL=https://webhook.example.com/darkpipe

# Optional — external healthcheck ping URL (e.g., Healthchecks.io)
# MONITOR_HEALTHCHECK_URL=https://hc-ping.com/your-uuid

# Optional — TLS certificate paths to monitor (comma-separated)
# MONITOR_CERT_PATHS=/etc/letsencrypt/live/example.com/fullchain.pem

# -----------------------------------------------------------------------------
# Webmail (Roundcube)
# Source: docker-compose.yml (roundcube service)
# These are container-internal defaults; override only if needed.
# -----------------------------------------------------------------------------

# Optional — database type for Roundcube
# ROUNDCUBEMAIL_DB_TYPE=sqlite

# Optional — max upload file size
# ROUNDCUBEMAIL_UPLOAD_MAX_FILESIZE=25M

# -----------------------------------------------------------------------------
# Webmail (SnappyMail)
# Source: docker-compose.yml (snappymail service)
# These are container-internal defaults; override only if needed.
# -----------------------------------------------------------------------------

# Optional — max upload size
# UPLOAD_MAX_SIZE=25M

# Optional — log to stdout instead of file
# LOG_TO_STDOUT=true

# Optional — PHP memory limit
# MEMORY_LIMIT=128M

# -----------------------------------------------------------------------------
# Radicale (CalDAV/CardDAV)
# Source: docker-compose.yml (radicale service)
# Only used with Maddy or Postfix+Dovecot profiles.
# -----------------------------------------------------------------------------

# Optional — Radicale config file path (container-internal)
# RADICALE_CONFIG=/config/config
